---
interface Props {
  items: string[];
  compact?: boolean;
}

const { items, compact = false } = Astro.props;
---

<ul class:list={['flex flex-wrap gap-2', compact ? 'text-xs' : 'text-sm']}>
  {
    items.map((item) => (
      <li class="rounded-full border border-white/15 bg-white/5 px-3 py-1 text-ink-50 transition hover:border-accent-400/60 hover:bg-accent-400/10">{item}</li>
    ))
  }
</ul>